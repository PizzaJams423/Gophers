@charset "utf-8";

html, body { background: rgb(255, 247, 237); }

:root { --gopher-footer-offset: 0px; --chat-z: 99999; }

.fade-in { opacity: 0; transition: opacity 0.35s ease-in; }

.fade-in.show { opacity: 1; }

.tab { border-radius: 1rem; padding: 0.5rem 0.75rem; font-weight: 600; box-shadow: rgba(0, 0, 0, 0.08) 0px 1px 2px; }

.tab.active { background: rgb(245, 158, 11); color: rgb(255, 255, 255); }

.tab.inactive { background: rgb(255, 255, 255); }

.tab.inactive:hover { background: rgb(255, 251, 235); }

.card { background: rgb(255, 255, 255); border-radius: 1rem; box-shadow: rgba(0, 0, 0, 0.08) 0px 1px 4px; }

.chat-launcher, .chat-panel, .chat-panel * { box-sizing: border-box; font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }

.chat-launcher { position: fixed; right: 20px; bottom: calc(var(--gopher-footer-offset, 0px) + 20px); width: 64px; height: 64px; border: 0px; border-radius: 999px; background: linear-gradient(135deg, rgb(245, 158, 11), rgb(251, 191, 36)); color: rgb(255, 255, 255); display: inline-flex; align-items: center; justify-content: center; box-shadow: rgba(245, 158, 11, 0.34) 0px 16px 34px; cursor: pointer; z-index: var(--chat-z); transition: transform 180ms, box-shadow 180ms; pointer-events: auto; }

.chat-launcher:hover { transform: translateY(-1px); box-shadow: rgba(245, 158, 11, 0.38) 0px 18px 38px; }

.chat-launcher:focus-visible, .chat-close:focus-visible, .chat-send:focus-visible, .chat-input:focus-visible { outline: rgba(245, 158, 11, 0.3) solid 3px; outline-offset: 3px; }

.chat-panel { position: fixed; inset: 0px; width: 100vw; height: 100vh; background: rgb(255, 250, 241); border: 0px; border-radius: 0px; box-shadow: none; overflow: hidden; display: none; flex-direction: column; z-index: var(--chat-z); }

.chat-header { background: linear-gradient(135deg, rgb(180, 83, 9), rgb(245, 158, 11)); color: rgb(255, 255, 255); padding: 18px 18px 16px; display: flex; justify-content: space-between; gap: 12px; align-items: flex-start; flex: 0 0 auto; }

.chat-title { margin: 0px; font-family: Fraunces, Georgia, serif; font-size: 1.16rem; font-weight: 700; letter-spacing: -0.02em; }

.chat-subtitle { margin: 6px 0px 0px; font-size: 0.92rem; line-height: 1.45; color: rgba(255, 255, 255, 0.9); }

.chat-close { width: 38px; height: 38px; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.22); background: rgba(255, 255, 255, 0.12); color: rgb(255, 255, 255); cursor: pointer; flex: 0 0 auto; }

.chat-body { flex: 1 1 0%; overflow: auto; padding: 16px; background: linear-gradient(rgb(255, 253, 248) 0%, rgb(255, 247, 237) 100%); }

.chat-row { display: flex; margin-bottom: 12px; }

.chat-row.bot { justify-content: flex-start; }

.chat-row.user { justify-content: flex-end; }

.bot-message-wrap { display: flex; align-items: flex-start; max-width: 84%; }

.bot-avatar { width: 34px; height: 34px; border-radius: 999px; object-fit: cover; flex: 0 0 auto; margin-right: 10px; margin-top: 2px; }

.bubble { padding: 12px 14px; border-radius: 16px; font-size: 0.96rem; line-height: 1.58; white-space: pre-wrap; }

.bot .bubble { background: rgb(255, 251, 235); border: 1px solid rgba(245, 158, 11, 0.12); color: rgb(41, 37, 36); border-bottom-left-radius: 6px; }

.user .bubble { background: rgb(245, 158, 11); color: rgb(255, 255, 255); border-bottom-right-radius: 6px; max-width: 84%; }

.chat-footer { border-top: 1px solid rgba(245, 158, 11, 0.12); padding: 12px; background: rgb(255, 255, 255); flex: 0 0 auto; }

.chat-note { font-size: 0.76rem; color: rgb(87, 83, 78); margin: 0px 0px 10px; }

.chat-form { display: grid; grid-template-columns: 1fr auto; gap: 10px; align-items: end; }

.chat-input { width: 100%; min-height: 48px; max-height: 120px; resize: vertical; border: 1px solid rgba(245, 158, 11, 0.18); border-radius: 14px; padding: 12px 14px; font: inherit; color: rgb(41, 37, 36); background: rgb(255, 255, 255); }

.chat-send { min-width: 52px; height: 48px; padding: 0px 16px; border: 0px; border-radius: 14px; background: rgb(245, 158, 11); color: rgb(255, 255, 255); font-weight: 700; cursor: pointer; }

.sr-only { position: absolute; width: 1px; height: 1px; padding: 0px; margin: -1px; overflow: hidden; clip: rect(0px, 0px, 0px, 0px); white-space: nowrap; border: 0px; }

@media (max-width: 640px) {
  .chat-launcher { right: 16px; bottom: calc(var(--gopher-footer-offset, 0px) + 16px); width: 60px; height: 60px; }
  .chat-panel { inset: 0px; width: 100vw; height: 100vh; }
}

@media (prefers-reduced-motion: reduce) {
  .chat-launcher, .chat-panel, .chat-panel * { scroll-behavior: auto; transition: none !important; }
}
